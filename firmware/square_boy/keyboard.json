{
    "manufacturer": "Leo Maskell",
    "keyboard_name": "square_boy",
    "maintainer": "Leo Maskell",
    "development_board": "promicro_rp2040",
    "diode_direction": "COL2ROW",
    "features": {
        "bootmagic": true,
        "command": false,
        "console": false,
        "extrakey": true,
        "mousekey": true,
        "nkro": true,
        "encoder": true,
        "encoder_map": true
    },

    "matrix_pins": {
        "cols": ["GP18", "GP10", "GP9"],
        "rows": ["GP3", "GP6", "GP7"]
    },
    "processor": "RP2040",
    "url": "www.github.com/LeoMaskell/squareBoy",
    "usb": {
        "device_version": "1.0.0",
        "pid": "0x0000",
        "vid": "0xFEED"
    },
    "encoder": {
    "rotary": [
      {
        "pin_a": "GP0",
        "pin_b": "GP1",
        //"driver": "quadrature",
        "resolution": 4,
       // "pin_switch": "D2"
        }
    ]
    },

    "layouts": {
        "LAYOUT": {
            "layout": [
                {"matrix": [0, 0], "x": 0, "y": 0},
                {"matrix": [0, 1], "x": 1, "y": 0},
                {"matrix": [0, 2], "x": 2, "y": 0},
                {"matrix": [1, 0], "x": 0, "y": 1},
                {"matrix": [1, 1], "x": 1, "y": 1},
                {"matrix": [1, 2], "x": 2, "y": 1},
                {"matrix": [2, 0], "x": 0, "y": 2},
                {"matrix": [2, 1], "x": 1, "y": 2},
                {"matrix": [2, 2], "x": 2, "y": 2}
            ]
        }
    }
}
